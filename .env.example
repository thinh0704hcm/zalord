# ─────────────────────────────────────────────────────────────────────────────
# zalord — environment variables
# Copy to .env and fill in real values. .env is gitignored.
#
# All values below are READ BY docker-compose.yml. Each service-specific
# compose block hardcodes its own DB hostname (e.g. POSTGRES_HOST: postgres-auth)
# so there's no global POSTGRES_HOST var here — services find their DB by
# compose service name.
# ─────────────────────────────────────────────────────────────────────────────

# ── Postgres (shared credentials across every per-service container) ──
POSTGRES_USER=zalord
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_AUTH_HOST_PORT=6433
POSTGRES_USER_HOST_PORT=6434

# ── Redis (shared coordination layer) ──
REDIS_HOST_PORT=6380

# ── Nginx ──
NGINX_HTTP_PORT=80

# ── auth-service ──
AUTH_SERVICE_HOST_PORT=8081

# ── user-service ──
USER_SERVICE_HOST_PORT=8082

# ── JWT (shared by every service that issues or verifies tokens) ──
JWT_SECRET=change-me-min-32-chars-aaaaaaaaaaaa
JWT_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7
JWT_ISSUER=zalord
JWT_AUDIENCE=zalord-clients

# ── Reserved for Week 2+ (Kafka, ScyllaDB, MinIO, FCM) ──
# KAFKA_HOST_PORT=9092
# SCYLLA_HOST_PORT=9042
# MINIO_ROOT_USER=minioadmin
# MINIO_ROOT_PASSWORD=change-me-minio
# MINIO_BUCKET=zalord-media
# MINIO_HOST_PORT=9000
# MINIO_CONSOLE_HOST_PORT=9001
# FCM_PROJECT_ID=
# FCM_CREDENTIALS_JSON=
