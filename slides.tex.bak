\begin{alertblock}{[PLACEHOLDER --- chụp hình]}
\centering
\textit{GitHub Actions → tab Actions của repo → chọn workflow run thành công → chụp màn hình các steps xanh}
\end{alertblock}
\end{frame}

\begin{frame}{Versioning \& Rollback Strategy (Req 15)}
\begin{columns}[T]
\column{0.5\textwidth}
\begin{block}{Image Versioning}
\begin{itemize}
  \item Mỗi image tagged với \textbf{Git SHA}:
    \begin{itemize}
      \item \small \texttt{docker.io/\{user\}/zalord-auth:\{sha\}}
      \item \small \texttt{docker.io/\{user\}/zalord-chat:\{sha\}}
      \item \small ...
    \end{itemize}
  \item Sau khi deploy thành công: promote \texttt{:latest} tag
  \item \textbf{Selective build}: chỉ rebuild service có file thay đổi → tiết kiệm thời gian CI
  \item Không có image nào bị overwrite --- SHA tag immutable
\end{itemize}
\end{block}
\begin{block}{Rollback}
\begin{itemize}
  \item K8s giữ revision history của Deployment
  \item \texttt{kubectl rollout undo deployment/auth-service -n zalord-dev} → về image SHA của commit trước
  \item \texttt{kubectl rollout status} trong pipeline → fail fast (180s) nếu pods không healthy
\end{itemize}
\end{block}

\column{0.5\textwidth}
\begin{alertblock}{Testing trong CI --- Chưa có}
\textbf{[PLACEHOLDER]}\\[0.2cm]
CI/CD pipeline hiện tại: build + deploy. Chưa có bước automated testing.\\[0.2cm]
Nên bổ sung:
\begin{itemize}
  \item \small Unit tests (JUnit 5 cho Java, Go test cho Go)
  \item \small Integration tests (Testcontainers)
  \item \small Contract tests giữa services
\end{itemize}
\end{alertblock}
\vspace{0.2cm}
\begin{alertblock}{[PLACEHOLDER --- chụp hình]}
\centering
\textit{Docker Hub repository}\\
\textit{hiển thị tags theo SHA:}\\
\texttt{zalord-auth:abc1234}\\
\texttt{zalord-chat:abc1234}\\
\textit{...}
\end{alertblock}
\end{columns}
\end{frame}

% ============================================================
\section{Resiliency Scenarios}
% ============================================================

\begin{frame}{Scenario 1: Circuit Breaker Activation (Req 16)}
\begin{columns}[T]
\column{0.5\textwidth}
\begin{block}{Scenario: media-service xuống → CB open}
\begin{enumerate}
  \item Kill media-service pod:\\
    \texttt{kubectl delete pod media-service-xxx}
  \item Gửi message có attachment qua API
  \item Observe: \textbf{circuit breaker OPEN} sau $>$50\% failures trong 10 calls (Resilience4j)
  \item Response: fallback method trả về error (không hang)
  \item Restart media-service pod (K8s tự restart)
  \item Observe: CB → HALF-OPEN → 3 probe requests → CLOSED
\end{enumerate}
\end{block}

\column{0.5\textwidth}
\begin{alertblock}{[PLACEHOLDER --- chụp hình/log]}
\centering
\textit{Logs của message-service:}\\
\textit{--- CB state: CLOSED → OPEN}\\
\textit{--- Fallback called}\\
\textit{--- CB state: OPEN → HALF-OPEN}\\
\textit{--- CB state: HALF-OPEN → CLOSED}\\[0.3cm]
\textit{Hoặc Grafana metric panel cho}\\
\textit{Resilience4j state transitions}
\end{alertblock}
\begin{block}{Kết quả kỳ vọng}
\begin{itemize}
  \item Hệ thống không crash khi media-service lỗi
  \item Fallback response trả về ngay (không chờ timeout)
  \item Tự recover khi media-service lên lại
\end{itemize}
\end{block}
\end{columns}
\end{frame}

\begin{frame}{Scenario 2: Pod Crash \& Self-Healing (Req 16)}
\begin{columns}[T]
\column{0.5\textwidth}
\begin{block}{Scenario: chat-service pod crash}
\begin{enumerate}
  \item Client A và B đang chat real-time
  \item \texttt{kubectl delete pod chat-service-xxx -n zalord-dev}
  \item K8s phát hiện pod gone → tạo pod mới (Deployment replicas=1)
  \item Frontend WebSocket: \textbf{exponential backoff reconnect} (cap 15s, logic trong \texttt{websocket.ts})
  \item Pod mới Ready → clients reconnect thành công
\end{enumerate}
\end{block}
\begin{block}{Scenario 3: Outbox resiliency}
\begin{enumerate}
  \item Tắt RabbitMQ tạm thời
  \item Gửi messages → lưu vào \texttt{outbox\_events} table (atomic với message)
  \item Bật lại RabbitMQ
  \item \textbf{OutboxScheduler} (poll 3s) phát hiện unpublished events → publish
  \item Không mất message nào
\end{enumerate}
\end{block}

\column{0.5\textwidth}
\begin{alertblock}{[PLACEHOLDER --- chụp hình]}
\centering
\texttt{kubectl get pods -n zalord-dev}\\[0.2cm]
\textit{Chụp: chat-service pod}\\
\textit{RESTARTS count = 1, Running}\\[0.3cm]
\textit{Frontend console log:}\\
\textit{--- WS disconnected}\\
\textit{--- Reconnecting in 1s...}\\
\textit{--- Reconnecting in 2s...}\\
\textit{--- WS connected}
\end{alertblock}
\begin{alertblock}{[PLACEHOLDER]}
\centering
\textit{Grafana: HTTP request rate}\\
\textit{dip khi pod đang restart,}\\
\textit{recover sau reconnect}
\end{alertblock}
\end{columns}
\end{frame}

% ============================================================
\section{Kết luận}
% ============================================================

\begin{frame}{Tổng kết}
\begin{columns}[T]
\column{0.5\textwidth}
\begin{block}{Đã triển khai}
\begin{itemize}
  \item[\checkmark] DB-per-service (6 PostgreSQL + Redis + MinIO)
  \item[\checkmark] Transactional Outbox (auth, message services)
  \item[\checkmark] CQRS (message-service InboxProjector)
  \item[\checkmark] Event-driven (RabbitMQ/Kafka switchable)
  \item[\checkmark] gRPC sync + Circuit Breaker (Resilience4j)
  \item[\checkmark] Kong API Gateway (JWT, rate-limit, CORS, Lua)
  \item[\checkmark] JWT HS256 auth (không cần OAuth2/Keycloak)
  \item[\checkmark] ConfigMap + SOPS-encrypted Secrets
  \item[\checkmark] Multi-stage Dockerfile, Docker Compose
  \item[\checkmark] Kubernetes (k3s, Kustomize)
  \item[\checkmark] CI/CD GitHub Actions → Docker Hub → VPS
  \item[\checkmark] Prometheus + Grafana monitoring
  \item[\checkmark] Swagger/OpenAPI aggregation
\end{itemize}
\end{block}

\column{0.5\textwidth}
\begin{alertblock}{Chưa triển khai / Không phù hợp}
\begin{itemize}
  \item \textcolor{orange}{OpenTelemetry} distributed tracing (chưa implement)
  \item \textcolor{orange}{Automated testing} trong CI (chưa implement)
  \item \textcolor{gray}{ELK Stack} --- resource constraint; stdout logging đủ cho scope này
  \item \textcolor{gray}{Saga Pattern} --- không có distributed transaction đủ phức tạp
  \item \textcolor{gray}{OAuth2/Keycloak} --- không phù hợp: closed first-party system
  \item \textcolor{gray}{GCP} --- VPS + k3s thay thế (chi phí)
\end{itemize}
\end{alertblock}
\begin{block}{Xem chi tiết}
\texttt{EXPLANATION.md} --- giải thích kỹ lý do các requirement không áp dụng
\end{block}
\end{columns}
\end{frame}

