% ============================================================
\section{Triển khai Docker \& Kubernetes}
% ============================================================

\begin{frame}[fragile]{Dockerfile \& Docker Compose (Req 8)}
\begin{columns}[T]
\column{0.5\textwidth}
\begin{block}{Multi-Stage Dockerfile --- Java (auth-service)}
\begin{lstlisting}
# Stage 1: Build
FROM eclipse-temurin:21-jdk-jammy AS build
WORKDIR /workspace
COPY mvnw . && COPY .mvn .mvn
COPY pom.xml .
RUN chmod +x mvnw && ./mvnw -B dependency:go-offline
# Layer cache: deps downloaded before source copy
COPY src src
RUN ./mvnw -B -DskipTests clean package \
  && java -Djarmode=layertools -jar target/*.jar \
     extract --destination target/extracted

# Stage 2: Runtime (JRE only, alpine = small)
FROM eclipse-temurin:21-jre-alpine
RUN addgroup -S spring && adduser -S spring -G spring
USER spring:spring
COPY --from=build /workspace/target/extracted/ ./
EXPOSE 8081
\end{lstlisting}
\end{block}

\column{0.5\textwidth}
\begin{block}{Multi-Stage Dockerfile --- Go (chat-service)}
\begin{lstlisting}
# Stage 1: Build
FROM golang:1.26.1-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download      # deps cached separately
COPY . .
RUN CGO_ENABLED=0 go build -o server ./cmd/server

# Stage 2: Runtime (scratch-like, ~8MB)
FROM alpine:latest
WORKDIR /app
COPY --from=builder /app/server .
EXPOSE 8084
CMD ["./server"]
\end{lstlisting}
\end{block}
\begin{block}{Docker Compose}
\begin{itemize}
  \item 20+ containers, 1 network \texttt{zalord-net}
  \item Named volumes per DB (pgdata\_auth, ..., miniodata, redisdata)
  \item Env vars từ \texttt{.env} file, không hardcode
\end{itemize}
\end{block}
\end{columns}
\end{frame}

\begin{frame}{Kubernetes / k3s (Req 8)}
\begin{columns}[T]
\column{0.52\textwidth}
\begin{block}{Kustomize Overlays}
\begin{itemize}
  \item Path: \texttt{deploy/k8s/overlays/dev/}
  \item Namespace: \texttt{zalord-dev}
  \item \textbf{Workloads}: 7 Deployments (services) + StatefulSets (Kafka, RabbitMQ, Redis, PostgreSQL×6, MinIO)
  \item \textbf{Resources}: requests/limits per container (e.g. auth: 100m/384Mi req, 500m/768Mi limit)
  \item \textbf{Probes}: TCP liveness, HTTP readiness (\texttt{/health})
  \item \textbf{Secrets}: SOPS + Age encryption (\texttt{*.secret.enc.yaml}) --- decrypted by CI/CD
\end{itemize}
\end{block}

