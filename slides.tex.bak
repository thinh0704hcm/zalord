\begin{frame}{Service Discovery \& Load Balancing (Req 9)}
\begin{columns}[T]
\column{0.5\textwidth}
\begin{block}{Service Discovery --- K8s DNS}
\begin{itemize}
  \item K8s tự tạo DNS entry cho mỗi ClusterIP Service
  \item \texttt{auth-service.zalord-dev.svc.cluster.local}
  \item Các service gọi nhau qua tên service (e.g. \texttt{http://user-service:8082})
  \item \textbf{KHÔNG cần Eureka hay Consul} --- K8s DNS thay thế hoàn toàn
\end{itemize}
\end{block}
\begin{block}{Cấu hình gRPC target}
\begin{itemize}
  \item \texttt{ZALORD\_USER\_SERVICE\_GRPC\_TARGET=user-service:9082}
  \item \texttt{ZALORD\_MEDIA\_SERVICE\_GRPC\_TARGET=media-service:9086}
  \item DNS resolve → ClusterIP → Pod IP
\end{itemize}
\end{block}

\column{0.5\textwidth}
\begin{block}{Load Balancing --- Server-side}
\begin{center}
\begin{tikzpicture}[
  box/.style={rectangle, draw, rounded corners=2pt, font=\tiny,
