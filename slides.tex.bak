]
\node[step] (trigger) at (0, 0)    {Trigger\\{\tiny push to main (backend/** changed)}};
\node[step] (detect)  at (3.8, 0)  {Detect changed\\services\\{\tiny git diff --name-only}};
\node[step] (build)   at (7.6, 0)  {Build \& Push\\Docker images\\{\tiny Buildx linux/amd64}};
\node[step] (registry) at (11.4,0) {Docker Hub\\{\tiny :\{sha\} tag}};

\node[step] (decrypt) at (0, -1.5)   {Decrypt Secrets\\{\tiny SOPS + Age key}\\{\tiny (GitHub Actions Secret)}};
\node[step] (ssh)     at (3.8, -1.5) {SSH to VPS\\{\tiny pre-pull images to containerd}};
\node[step] (apply)   at (7.6, -1.5) {kubectl apply\\{\tiny -n zalord-dev}};
