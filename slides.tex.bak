\section{CI/CD \& Triển khai}
% ============================================================

\begin{frame}{GitHub Actions Pipeline (Req 15)}
\begin{center}
\begin{tikzpicture}[
  step/.style={rectangle, draw, rounded corners=3pt, font=\small,
