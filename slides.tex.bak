\centering
\textit{Chụp màn hình Swagger UI tại}\\
\textit{http://localhost:8080/docs}\\
\textit{hiển thị API docs từ tất cả 7 services}
\end{alertblock}
\end{columns}
\end{frame}

% ============================================================
\section{Thiết kế \& Quản lý cơ sở dữ liệu}
% ============================================================

\begin{frame}{DB per Service --- Consistency \& CAP (Req 6)}
\begin{columns}[T]
\column{0.5\textwidth}
\begin{block}{DB per Service}
\begin{itemize}
  \item 6 PostgreSQL instances độc lập + Redis + MinIO
  \item Không service nào truy cập trực tiếp DB của service khác
  \item \textbf{Strong consistency}: trong 1 service (ACID transactions)
  \item \textbf{Eventual consistency}: cross-service qua event bus
    \begin{itemize}
      \item \small group member change → message-service projection có độ trễ nhỏ
      \item \small message.created → inbox view update không đồng thời
    \end{itemize}
\end{itemize}
\end{block}
\begin{block}{CAP Theorem}
\begin{itemize}
  \item PostgreSQL: \textbf{CP} (Consistency + Partition Tolerance)
  \item Chấp nhận availability giảm khi partition
  \item Redis: \textbf{AP} --- eventual consistency cho presence data
\end{itemize}
\end{block}

\column{0.5\textwidth}
\begin{block}{Consistency cần thiết ở đâu?}
\begin{itemize}
  \item \textbf{Strong}: auth (login/register), message persist (không mất tin nhắn)
  \item \textbf{Eventual}: inbox unread count, notification, presence status
  \item \textbf{Saga}: \textcolor{red}{KHÔNG áp dụng} --- chỉ có 2-step registration (gRPC + circuit breaker đủ)
\end{itemize}
\end{block}
\begin{alertblock}{Không có Saga Pattern}
Lý do: không tồn tại distributed transaction nào đủ phức tạp. Flow dài nhất là 2 bước (auth → user). Xem \texttt{EXPLANATION.md}.
\end{alertblock}
\end{columns}
\end{frame}

\begin{frame}{Transactional Outbox Pattern (Req 7)}
\begin{center}
\begin{tikzpicture}[
  box/.style={rectangle, draw, rounded corners=3pt, font=\small,
              align=center, minimum width=3cm, minimum height=0.7cm},
  arr/.style={->, >=Stealth, thick},
  scale=0.95
]
% Business logic
\node[box, fill=blue!15] (biz) at (0, 3.5) {Business Logic\\(e.g. send message)};

% DB transaction - wrap both in a box
\node[box, fill=orange!15] (msg_t)  at (4,    3.9) {messages table\\(business data)};
\node[box, fill=orange!25] (outbox) at (4,    3.0) {outbox\_events table\\{\tiny routing\_key, payload (JSONB), published\_at}};

\begin{scope}[on background layer]
\node[draw, dashed, rounded corners=5pt, fill=gray!10,
      fit=(msg_t)(outbox), inner sep=8pt] (txbox) {};
\end{scope}
\node[font=\tiny\bfseries, gray] at (5.5, 4.4) {Atomic DB Transaction};

% OutboxScheduler
\node[box, fill=green!15] (sched) at (4, 1.5) {OutboxScheduler\\{\tiny poll every 3s, FOR UPDATE SKIP LOCKED, batch 100}};

% MQ
\node[box, fill=yellow!30] (mq) at (4, 0.2) {RabbitMQ / Kafka};

% Consumers
\node[box, fill=teal!15] (c1) at (1.5, -1.1) {chat-service\\(WebSocket)};
\node[box, fill=teal!15] (c2) at (4.5, -1.1) {notification-service};
\node[box, fill=teal!15] (c3) at (7.5, -1.1) {InboxProjector};

% Arrows
\draw[arr] (biz.east) -- (txbox.west) node[midway, above, font=\tiny] {atomic TX};
\draw[arr] (outbox.south) -- (sched.north);
\draw[arr] (sched.south) -- (mq.north) node[midway, right, font=\tiny] {publish};
\draw[arr] (mq.south) -- (c1.north);
\draw[arr] (mq.south) -- (c2.north);
\draw[arr] (mq.south) -- (c3.north);

% Implemented in label
\node[font=\tiny, gray, align=left] at (-1.5, 1.5)
  {Implemented in:\\auth-service\\message-service};

\end{tikzpicture}
