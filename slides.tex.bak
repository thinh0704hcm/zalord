% ============================================================
\section{Tổng quan hệ thống}
% ============================================================

\begin{frame}{Giới thiệu Zalord}
\begin{columns}[T]
\column{0.52\textwidth}
\begin{block}{Zalord là gì?}
\begin{itemize}
  \item Ứng dụng chat real-time kiến trúc \textbf{Microservices}
  \item \textbf{7 services} độc lập, polyglot Java / Go
  \item Hỗ trợ: nhắn tin 1-1, nhóm, file đính kèm, real-time presence
  \item Frontend: React 19 + TypeScript + Vite + WebSocket
\end{itemize}
\end{block}
\begin{block}{Tech stack tổng quan}
\begin{itemize}
  \item \textbf{Gateway}: Kong 3.7 (DB-less declarative)
  \item \textbf{Messaging}: RabbitMQ / Kafka (switchable)
  \item \textbf{Storage}: PostgreSQL ×6, Redis, MinIO (S3)
  \item \textbf{Observability}: Prometheus + Grafana
  \item \textbf{Deploy}: Docker Compose (dev) / k3s (prod)
  \item \textbf{CI/CD}: GitHub Actions → Docker Hub → VPS
\end{itemize}
\end{block}

\column{0.46\textwidth}
\begin{table}[h]
\centering
\small
\begin{tabular}{|l|l|r|}
\hline
\textbf{Service} & \textbf{Lang} & \textbf{Port} \\
\hline
auth-service & Java/Spring & 8081 \\
user-service & Go & 8082 \\
message-service & Java/Spring & 8083 \\
chat-service & Go & 8084 \\
group-service & Java/Spring & 8085 \\
media-service & Java/Spring & 8086 \\
notification-service & Go & 8087 \\
\hline
\end{tabular}
\end{table}
