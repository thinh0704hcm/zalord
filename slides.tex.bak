\begin{frame}{ConfigMap \& Secret trong Kubernetes (Req 12)}
\begin{columns}[T]
\column{0.5\textwidth}
\begin{block}{ConfigMap --- Non-sensitive config}
\begin{itemize}
  \item \textbf{Shared}: \texttt{shared-config.yaml}
    \begin{itemize}
      \item \small \texttt{EVENT\_BUS=rabbitmq}
      \item \small \texttt{RABBITMQ\_HOST=rabbitmq}
      \item \small \texttt{KAFKA\_BOOTSTRAP=kafka:9092}
      \item \small \texttt{REDIS\_HOST=redis}
      \item \small \texttt{JWT\_EXPIRY\_MINUTES=15}
    \end{itemize}
  \item \textbf{Per-service}: \texttt{\{svc\}-config.yaml} --- database host/port/name, gRPC targets, service-specific config
  \item Mount as env vars vào Deployment
\end{itemize}
\end{block}
\begin{block}{Tại sao cần ConfigMap?}
\begin{itemize}
  \item Thay đổi config không cần build lại Docker image
  \item Khác nhau giữa environments (dev/staging/prod) qua Kustomize overlays
\end{itemize}
\end{block}

\column{0.5\textwidth}
\begin{block}{Secret --- Sensitive data (SOPS encrypted)}
\begin{itemize}
  \item \textbf{Shared}: DB passwords, JWT\_SECRET, MQ credentials
  \item \textbf{Per-service}: database URLs với credentials
  \item Files: \texttt{*.secret.enc.yaml} --- encrypted với \textbf{SOPS + Age key}
  \item Age key lưu trong \textbf{GitHub Actions Secret}
  \item CI/CD decrypt tại deploy time: \texttt{sops -d file.enc.yaml}
  \item Secret encrypted at rest trong Git --- an toàn commit public repo
\end{itemize}
\end{block}
\begin{block}{Kong JWT Secret}
\texttt{kong.yml} chứa \texttt{\_\_JWT\_SECRET\_\_} placeholder. Container entrypoint dùng \texttt{sed} substitute từ K8s Secret env var. Secret không bao giờ nằm trong file config.
\end{block}
\end{columns}
\end{frame}

