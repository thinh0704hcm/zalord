\section{API Gateway}
% ============================================================

\begin{frame}{Kong API Gateway --- Filter Chain (Req 10)}
\begin{columns}[T]
\column{0.45\textwidth}
\begin{center}
\begin{tikzpicture}[
  plug/.style={rectangle, draw, rounded corners=3pt, font=\small,
               align=center, minimum width=3.8cm, minimum height=0.65cm},
  arr/.style={->, >=Stealth, thick},
  scale=0.88
]
\node[draw, ellipse, fill=gray!15, font=\small] (cli) at (0, 7.2) {Client Request};

\node[plug, fill=orange!20] (rl)   at (0, 6.2) {rate-limiting plugin\\{\tiny 600/min global, 10/min auth}};
\node[plug, fill=yellow!20] (cors) at (0, 5.3) {cors plugin\\{\tiny origins: *, credentials: true}};
\node[plug, fill=red!15]    (jwt)  at (0, 4.4) {jwt plugin\\{\tiny HS256, verify exp, per-route}};
\node[plug, fill=teal!20]   (lua)  at (0, 3.5) {pre-function (Lua)\\{\tiny strip X-User-Id/Roles (forgery)}\\{\tiny inject from JWT sub/roles claims}};
\node[plug, fill=blue!15]   (up)   at (0, 2.4) {Upstream Service\\{\tiny nhận X-User-Id, X-User-Roles}};

\draw[arr] (cli)  -- (rl);
\draw[arr] (rl)   -- (cors);
\draw[arr] (cors) -- (jwt);
\draw[arr] (jwt)  -- (lua);
\draw[arr] (lua)  -- (up);

\node[font=\tiny, gray, align=left] at (3, 4.4)
  {public routes\\bypass jwt};

\end{tikzpicture}
\end{center}

\column{0.53\textwidth}
\begin{block}{Các tính năng Kong đã cấu hình}
\begin{itemize}
  \item \textbf{Rate Limiting}: 600 req/min per IP (global), 10 req/min (auth routes \texttt{/login, /register})
  \item \textbf{CORS}: global, tất cả origins (dev), credentials enabled
  \item \textbf{JWT Filter}: validate HS256, kiểm tra \texttt{exp} claim
  \item \textbf{Identity Injection}: Lua pre-function inject \texttt{X-User-Id} (từ \texttt{sub}) và \texttt{X-User-Roles} (từ \texttt{roles} array)
  \item \textbf{Prometheus}: metrics tại admin \texttt{:8001/metrics}
\end{itemize}
\end{block}
\begin{block}{Path Rewriting}
\begin{itemize}
  \item \texttt{/api-docs/auth} → auth-service \texttt{/v3/api-docs} (\texttt{strip\_path: true})
  \item Main API routes: \texttt{strip\_path: false} (forward nguyên path)
\end{itemize}
\end{block}
\begin{block}{WebSocket}
\texttt{/ws/chat?token=\{jwt\}} --- browser không set custom header khi upgrade, token qua query param
\end{block}
\end{columns}
\end{frame}

\begin{frame}{Kong --- DB-less Mode \& Route Table (Req 10)}
\begin{columns}[T]
\column{0.55\textwidth}
\begin{block}{Declarative Config (DB-less)}
\begin{itemize}
  \item Config tại \texttt{infra/kong/kong.yml} --- version control được
  \item \textbf{Cùng 1 file} cho Docker Compose (dev) và K8s (prod) --- không có config drift
  \item \texttt{\_\_JWT\_SECRET\_\_} placeholder được \texttt{sed} substitute từ env var khi container start --- secret không lưu trong file
  \item Kong \textbf{KHÔNG phải K8s Ingress Controller} --- standalone deployment. Xem \texttt{EXPLANATION.md} để biết lý do.
\end{itemize}
\end{block}
