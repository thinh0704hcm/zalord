% ============================================================
\section{Domain-Driven Design}
% ============================================================

\begin{frame}{Tại sao không dùng Modulithic? (Req 1)}
\begin{columns}[T]
\column{0.5\textwidth}
\begin{block}{Lý do chọn Microservices}
\begin{itemize}
  \item \textbf{Polyglot language}: chat-service dùng Go (goroutines) cho WebSocket fan-out hiệu năng cao; business logic dùng Java Spring Boot
  \item \textbf{Independent scaling}: chat-service cần scale riêng khi traffic tăng, không kéo theo auth-service
  \item \textbf{Independent deploy}: cập nhật media-service không ảnh hưởng chat real-time
  \item \textbf{Fault isolation}: media-service lỗi không kéo sập toàn bộ hệ thống
\end{itemize}
\end{block}

\column{0.5\textwidth}
\begin{block}{Nếu là Modulithic\ldots}
\begin{itemize}
  \item Không thể mix Go + Java trong 1 process
  \item Scale toàn bộ khi chỉ cần scale 1 module
  \item Deploy toàn bộ khi chỉ thay đổi 1 module
  \item 1 memory leak / goroutine leak làm sập tất cả
\end{itemize}
\end{block}
\begin{alertblock}{Lưu ý trung thực}
Ở quy mô student project, modulithic vẫn hoạt động tốt. Microservices là lựa chọn \textbf{học thuật + kỹ năng}, phù hợp với mục tiêu môn học.
\end{alertblock}
\end{columns}
\end{frame}

\begin{frame}{Phân chia theo DDD --- Bounded Contexts (Req 2)}
\begin{columns}[T]
\column{0.52\textwidth}
\begin{table}[h]
\centering
\tiny
\begin{tabular}{|l|l|l|}
\hline
\textbf{Service} & \textbf{Bounded Context} & \textbf{Aggregate Root} \\
\hline
auth-service & Authentication & Account, Session \\
user-service & UserProfile & UserProfile \\
message-service & Messaging + Inbox & Message, ConversationView \\
chat-service & RealtimeDelivery & Connection \\
group-service & GroupManagement & Group \\
media-service & MediaStorage & MediaItem \\
notification-service & Notification & Notification \\
\hline
\end{tabular}
\end{table}

\begin{block}{Nguyên tắc phân chia}
\begin{itemize}
  \item Mỗi service có \textbf{1 bounded context} độc lập
  \item Không share entity/table giữa các service
  \item Giao tiếp qua \textbf{API / Event} (không gọi thẳng DB)
  \item group.id được tái sử dụng làm conversation.id (shared key, không shared schema)
\end{itemize}
\end{block}

