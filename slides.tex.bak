\end{tikzpicture}
\end{center}
\end{block}
\begin{block}{Server-side vs Client-side LB}
\begin{itemize}
  \item \textbf{Server-side} (kube-proxy): LB xảy ra ở K8s layer, client không cần library (Ribbon). Works với mọi ngôn ngữ.
  \item Client-side LB (Ribbon/gRPC native): phù hợp khi KHÔNG có K8s
\end{itemize}
\end{block}
\end{columns}
\end{frame}

