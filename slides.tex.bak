\begin{frame}{ELK \& OpenTelemetry --- Chưa triển khai (Req 13)}
\begin{columns}[T]
\column{0.5\textwidth}
\begin{alertblock}{ELK Stack --- Không triển khai}
\begin{itemize}
  \item ELK (Elasticsearch + Logstash + Kibana) cần $\sim$3--5 GB RAM riêng --- không khả thi trên VPS hiện tại
  \item \textbf{Hiện tại}: structured logging ra stdout
    \begin{itemize}
      \item \small Go: \texttt{go.uber.org/zap} (JSON format)
      \item \small Java: SLF4J + Logback (JSON appender)
    \end{itemize}
  \item \textbf{12-factor principle}: log là event stream, không phải file
  \item \textbf{Nếu scale lên}: Grafana Loki ($\sim$200 MB) là alternative nhẹ hơn, tích hợp native với Grafana
\end{itemize}
\end{alertblock}

\column{0.5\textwidth}
\begin{alertblock}{OpenTelemetry --- Chưa triển khai}
\textbf{[PLACEHOLDER]}\\[0.2cm]
OpenTelemetry distributed tracing sẽ cho phép:
\begin{itemize}
  \item \small Trace 1 request qua: Kong → message-service → media gRPC call → outbox → event bus → chat-service
  \item \small Xác định latency ở từng hop
  \item \small Tích hợp với Jaeger / Tempo (Grafana)
\end{itemize}
\vspace{0.2cm}
\textit{[Diagram: trace flow từ Kong request đến consumer cuối cùng]}
\end{alertblock}
\begin{block}{K8s Cluster Monitoring}
\begin{itemize}
  \item Dùng \textbf{Lens IDE} hoặc \textbf{k9s} CLI để giám sát cluster k3s
\end{itemize}
\begin{alertblock}{}
\centering\tiny [PLACEHOLDER --- chụp Lens/k9s với zalord-dev namespace]
\end{alertblock}
\end{block}
\end{columns}
\end{frame}

\begin{frame}{Timeout, Circuit Breaker \& Recovery (Req 14)}
\begin{columns}[T]
\column{0.5\textwidth}
\begin{center}
\begin{tikzpicture}[
  state/.style={rectangle, draw, rounded corners=4pt, font=\small\bfseries,
                align=center, minimum width=2.5cm, minimum height=0.8cm},
  arr/.style={->, >=Stealth, thick},
  scale=0.88
]
\node[state, fill=green!25]  (closed)   at (0, 4) {CLOSED\\{\tiny requests pass through}};
\node[state, fill=red!25]    (open)     at (0, 2) {OPEN\\{\tiny fast-fail, fallback}};
\node[state, fill=yellow!30] (half)     at (0, 0) {HALF-OPEN\\{\tiny 3 probe requests}};

\draw[arr] (closed) -- (open)
  node[midway, right, font=\tiny] {failure rate $>$50\%\\(10-call window)};
\draw[arr] (open) -- (half)
  node[midway, right, font=\tiny] {wait 30s};
\draw[arr] (half) to[bend right=45] (closed)
  node[midway, left, font=\tiny] {3 probes OK};
\draw[arr] (half) to[bend left=45] (open)
  node[midway, right, font=\tiny] {any probe fails};

\node[font=\tiny, gray] at (0, -0.8) {Resilience4j 2.2.0};
\end{tikzpicture}
\end{center}

\column{0.5\textwidth}
\begin{block}{Implementation}
\begin{itemize}
  \item \textbf{auth-service} → user-service gRPC:
    \begin{itemize}
      \item \small \texttt{@CircuitBreaker(name="userGrpc")}
      \item \small gRPC deadline: \textbf{5 giây}
      \item \small Fallback: \texttt{createProfileFallback()}
    \end{itemize}
  \item \textbf{message-service} → media-service gRPC:
    \begin{itemize}
      \item \small \texttt{@CircuitBreaker(name="mediaGrpc")}
      \item \small gRPC deadline: \textbf{3 giây} (hot path)
      \item \small Fallback: \texttt{validateFallback()}
    \end{itemize}
\end{itemize}
\end{block}
\begin{block}{Go services --- Error Handling}
\begin{itemize}
  \item \textbf{PermanentError}: drop message (ack), log error
  \item \textbf{Transient error}: nack + requeue → RabbitMQ retry
  \item Frontend WebSocket: exponential backoff reconnect (cap 15s)
\end{itemize}
\end{block}
\end{columns}
\end{frame}

