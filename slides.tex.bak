\begin{frame}{Thiết kế Endpoint \& Swagger (Req 5)}
\begin{columns}[T]
\column{0.5\textwidth}
\begin{block}{REST API --- Naming Convention}
\begin{itemize}
  \item Base path: \texttt{/api/v1/\{resource\}} (plural noun)
  \item \texttt{POST /api/v1/auth/register}
  \item \texttt{GET /api/v1/users}
  \item \texttt{GET /api/v1/conversations}
  \item \texttt{POST /api/v1/messages}
  \item \texttt{POST /api/v1/groups/\{id\}/members}
  \item \texttt{DELETE /api/v1/groups/\{id\}/members/\{uid\}}
  \item \texttt{POST /api/v1/media/upload-url}
  \item WebSocket: \texttt{/ws/chat?token=\{jwt\}}
\end{itemize}
\end{block}
\begin{block}{Error Response}
Spring Boot 3 RFC 7807 \textbf{ProblemDetail}:\\
\texttt{\{"type":..., "status":400,}\\
\texttt{ "detail":"...", "title":"..."\}}
\end{block}

\column{0.5\textwidth}
\begin{block}{Swagger / OpenAPI Aggregation}
\begin{itemize}
  \item Java services: \textbf{springdoc-openapi} → \texttt{/v3/api-docs}
  \item Go services: \textbf{swaggo} → \texttt{/v3/api-docs}
  \item Kong route \texttt{/api-docs/\{svc\}} → \texttt{strip\_path: true} → forward đến service \texttt{/v3/api-docs}
  \item \textbf{Swagger UI} container tại \texttt{/docs} aggregate tất cả
\end{itemize}
\end{block}
